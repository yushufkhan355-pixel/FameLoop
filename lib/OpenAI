const OpenAI = require('openai');

const openai = new OpenAI({
  apiKey: functions.config().openai.key,
});

exports.generateAITags = functions.https.onCall(async (data, context) => {
  if (!context.auth) throw new functions.https.HttpsError('unauthenticated', 'Auth required');
  
  const { prompt } = data; // e.g., "A video of a dog skateboarding"
  
  const response = await openai.chat.completions.create({
    model: "gpt-3.5-turbo",
    messages: [
      {role: "system", content: "You are a viral social media manager. Generate 3 catchy captions and 10 viral hashtags based on the video description."},
      {role: "user", content: prompt}
    ],
  });

  return { result: response.choices[0].message.content };
});
